# ============================================
# НАСТРОЙКИ REPETITOR BOT
# Скопируйте этот файл: cp .env.example .env
# Заполните значения ниже
# ============================================

# --- Telegram ---
# Получить у @BotFather в Telegram (обязательно!)
BOT_TOKEN=your_bot_token_here

# --- База данных ---
# Менять НЕ нужно если используете docker-compose
DATABASE_URL=postgresql+asyncpg://repetitor:changeme@db:5432/repetitor
DB_PASSWORD=changeme

# --- Redis ---
# Менять НЕ нужно если используете docker-compose
REDIS_URL=redis://redis:6379/0

# --- OpenAI (для проверки домашки) ---
# Получить на platform.openai.com (нужна карта)
# Без этого ключа проверка домашки не будет работать
OPENAI_API_KEY=sk-your-key-here

# --- Google Calendar (опционально) ---
# Без этого бот покажет стандартные слоты 09:00-18:00
# Для подключения: Google Cloud Console → API → Calendar API
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
GOOGLE_CALENDAR_ID=primary

# --- Оплата подписок ---
# Telegram Stars — встроен в Telegram, ничего настраивать не нужно!
# Менеджер для оплаты переводом на карту (пользователи пишут ему напрямую)
MANAGER_USERNAME=aileadflow

# --- Оплата пакетов уроков (опционально, через @BotFather) ---
# Нужно только если хочешь прямую оплату уроков в Telegram через ЮКассу
YOOKASSA_PROVIDER_TOKEN=

# --- Настройки приложения ---
TIMEZONE=Europe/Moscow
AI_RATE_LIMIT_PER_USER=20
DASHBOARD_SECRET_KEY=change-this-to-random-string
