# База данных
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/b2b_leads

# Redis
REDIS_URL=redis://localhost:6379

# AI
OPENAI_API_KEY=sk-...

# CRM (выбери один)
CRM_TYPE=bitrix24  # или amocrm, или internal

# Bitrix24
BITRIX24_WEBHOOK_URL=https://yourcompany.bitrix24.ru/rest/1/xxxxxxxx
BITRIX24_DEFAULT_MANAGER=1
BITRIX24_MANAGER_HIGH=2

# amoCRM
AMOCRM_DOMAIN=yourcompany.amocrm.ru
AMOCRM_TOKEN=your_token
AMOCRM_PIPELINE_ID=12345
AMOCRM_DEFAULT_MANAGER=0

# WhatsApp (Meta Business API)
WHATSAPP_TOKEN=your_token
WHATSAPP_PHONE_ID=your_phone_id

# Telegram (опционально)
TELEGRAM_BOT_TOKEN=123456:ABC...

# VK
VK_TOKEN=vk1.a.xxx
VK_GROUP_ID=123456789

# Email (Яндекс SMTP по умолчанию)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=yourmail@yandex.ru
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Название компании

# SMS (sms.ru)
SMSRU_API_ID=your_api_id
